DATABASE_URL="postgresql://username:password@ep-something.neon.tech/stubia_core?sslmode=require"
PORT=3001
JWT_SECRET="super-secret-jwt-key"
JWT_REFRESH_SECRET="super-secret-jwt-refresh-key"
NODE_ENV="development"

# AI Provider
AI_PROVIDER="openai" # anthropic | openai | gemini
AI_API_KEY="your-api-key"
AI_DEFAULT_MODEL="gpt-4o"
ALLOW_USER_SELECT_MODEL=false
AI_DAILY_LIMIT_PER_USER=20
AI_MAX_TOKENS=4096

# Supabase Storage Configuration
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="docs"
